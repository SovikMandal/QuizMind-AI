# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Database (matches docker-compose.yml) ────────────────
DATABASE_URL=postgresql://quizuser:quizpass@127.0.0.1:5434/quizapp

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6380

# ── Auth (JWT, HS256) ────────────────────────────────────
# Use long random strings in production.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── AI Provider (pluggable) ──────────────────────────────
# Options: gemini | anthropic
AI_PROVIDER=gemini
AI_API_KEY=
# Set to "true" to restrict AI generation to Pro/Premium users (US-25)
AI_REQUIRE_PAID=false/true
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-3-5-sonnet

# ── Cloudinary (avatar uploads) ──────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay (subscription payments) ─────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Email (Resend) ───────────────────────────────────────
# Get an API key at https://resend.com. Leave blank to disable email
# (password reset then falls back to a dev token outside production).
RESEND_API_KEY=
# Use "onboarding@resend.dev" for testing, or a verified-domain sender in prod.
MAIL_FROM=QuizMind AI <onboarding@resend.dev>
