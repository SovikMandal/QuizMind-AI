# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Database (matches docker-compose.yml) ────────────────
DATABASE_URL=postgresql://quizuser:quizpass@127.0.0.1:5434/quizapp
# DIRECT_URL is used by Prisma for MIGRATIONS only (the pooled/pgbouncer
# connection can't run them). Local Docker Postgres has no pooler, so this
# can equal DATABASE_URL. On Neon set:
#   DATABASE_URL = pooled string  (host has "-pooler", add &pgbouncer=true&connect_timeout=15)
#   DIRECT_URL   = direct string  (host WITHOUT "-pooler")
DIRECT_URL=postgresql://quizuser:quizpass@127.0.0.1:5434/quizapp

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6380

# ── Auth (JWT, HS256) ────────────────────────────────────
# Use long random strings in production.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── AI Provider (pluggable) ──────────────────────────────
# Options: gemini | anthropic | openrouter
AI_PROVIDER=gemini
AI_API_KEY=
# Set to "true" to restrict AI generation to Pro/Premium users (US-25)
AI_REQUIRE_PAID=false/true
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-3-5-sonnet
AI_API_KEY=<your OpenRouter API key>
OPENROUTER_MODEL=openrouter/owl-alpha

# ── Cloudinary (avatar uploads) ──────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay (subscription payments) ─────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Email (Brevo API) ────────────────────────────────────
# Get API key from: https://app.brevo.com/settings/keys/api
# Leave blank to disable email (codes print to console in dev)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=ad3a46001@smtp-brevo.com
SMTP_PASS=
MAIL_FROM=noreply@yourdomain.com

# ── OAuth: Google ────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# ── OAuth: GitHub ────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# "Authorization callback URL" must match GITHUB_REDIRECT_URI exactly.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4000/api/v1/auth/github/callback
