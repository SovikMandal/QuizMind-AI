# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Database (matches docker-compose.yml) ────────────────
DATABASE_URL=postgresql://quizuser:quizpass@127.0.0.1:5434/quizapp

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6380

# ── Auth (JWT, HS256) ────────────────────────────────────
# Use long random strings in production.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── AI Provider (pluggable) ──────────────────────────────
# Options: gemini | anthropic | openrouter
AI_PROVIDER=gemini
AI_API_KEY=
# Set to "true" to restrict AI generation to Pro/Premium users (US-25)
AI_REQUIRE_PAID=false/true
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-3-5-sonnet
AI_API_KEY=<your OpenRouter API key>
OPENROUTER_MODEL=openrouter/owl-alpha

# ── Cloudinary (avatar uploads) ──────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay (subscription payments) ─────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Email (Nodemailer + Brevo SMTP) ──────────────────────
# Brevo dashboard → SMTP & API → SMTP. Leave SMTP_USER/PASS blank to disable email
# (verification codes then print to the server console outside production).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Must be a sender verified in your Brevo account.
MAIL_FROM=QuizMind AI <no-reply@example.com>
